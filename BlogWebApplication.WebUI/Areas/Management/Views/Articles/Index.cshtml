@{
    ViewData["Title"] = "Makaleler";
}
@model ArticleListViewModel
<div class="container">

    <h1 class="mt-4">Makaleler</h1>
    @if (TempData["StatusMessage"] != null)
    {
        <div class="alert alert-success" role="alert">
            @TempData["StatusMessage"]
        </div>
    }

    <a href="@Url.Action("AddArticle", "Articles", new { area = "Management" })" class="btn btn-primary mb-3">Yeni Makale Ekle</a>
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Başlık</th>
                <th>Kategori</th>
                <th>Yazar</th>
                <th>Oluşturulma Tarihi</th>
                <th>Durumu</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var article in Model.Articles)
            {
                <tr>
                    <td>@article.Title</td>
                    <td>@article.Category.Name</td>
                    <td>@article.AppUser.UserName</td>
                    <td>@article.CreatedDate.ToString("dd/MM/yyyy")</td>
                    <td>
                        <span class="text-@(article.IsActive ? "success" : "warning")">@(article.IsActive ? "Aktif" : "Pasif")</span>
                    </td>
                    <td>
                        <a asp-area="Management" asp-controller="Articles" asp-action="EditArticle" asp-route-articleId="@article.Id" class="btn btn-sm btn-warning">Düzenle</a>
                        @{
                            if (User.IsInRole("SUPER ADMİN"))
                            {
                                <a asp-area="Management" asp-controller="Articles" asp-action="SoftDeleteArticle" asp-route-articleId="@article.Id" class="btn btn-sm btn-danger">Sil</a>
                            }
                        }

                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="justify-content-center">
        <ul class="pagination justify-content-center mb-4 mt-4 btn-block">
            @if (Model.ShowPrevious)
            {
                <li class="page-item">
                    <a class="page-link" asp-route-currentPage="@(Model.CurrentPage - 1)" asp-route-pageSize="@Model.PageSize">Önceki</a>
                </li>
            }

            @for (int i = 1; i < Model.TotalPages; i++)
            {
                <li class="page-item" @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-route-currentPage="@i" asp-route-pageSize="@Model.PageSize"> @i  </a>
                </li>
            }
            @if (Model.ShowNext)
            {
                <li class="page-item">
                    <a class="page-link" asp-route-currentPage="@(Model.CurrentPage + 1)" asp-route-pageSize="@Model.PageSize">Sonraki</a>
                </li>
            }

        </ul>
    </div>
</div>