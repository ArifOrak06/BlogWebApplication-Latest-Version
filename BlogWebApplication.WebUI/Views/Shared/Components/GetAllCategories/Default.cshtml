@model List<CategoryViewModel>



<div class="sidebar-item categories">
    <div class="sidebar-heading">
        <h2>Kategoriler</h2>
    </div>
    <div class="content">
        <ul>
            @if (Model.Count > 0 || Model is not null)
            {
                @foreach (var category in Model)
                {
                   
                    <li><a href="#">@category.Name</a></li>
                    
                }
                
            }
   
        </ul>
    </div>
</div>